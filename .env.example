# Environment variables for local development.
# Copy this file to .env and replace the values with your local settings.

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=auditai_dev

# JWT Settings
# Use 'dotnet user-secrets set "Jwt:Key" "your-secret-key"' to set this locally.
# Do not store the real key here.
JWT_KEY=
JWT_ISSUER=AuditAI
JWT_AUDIENCE=AuditAI.Users
