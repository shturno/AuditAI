# Environment variables for local development.
# Copy this file to .env and replace the values with your local settings.

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=auditai_dev

# JWT Settings
# Use a real secret outside source control. These are placeholders only.
JWT__ISSUER=AuditAI
JWT__AUDIENCE=AuditAI.Users
JWT__SECRET=replace-with-a-long-local-secret
JWT__EXPIRATION_MINUTES=60
